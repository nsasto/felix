<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Color Definitions -->
    <Color x:Key="PrimaryBackgroundColor">#1a1a2e</Color>
    <Color x:Key="SecondaryBackgroundColor">#0f3460</Color>
    <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
    <Color x:Key="SecondaryTextColor">#B0FFFFFF</Color>
    <Color x:Key="BorderColor">#FFFFFF</Color>
    <Color x:Key="SidebarBackgroundColor">#000000</Color>
    <Color x:Key="ToolbarBackgroundColor">#000000</Color>
    <Color x:Key="SearchBarBackgroundColor">#000000</Color>
    <Color x:Key="DataGridRowColor">#FFFFFF</Color>
    <Color x:Key="DataGridAlternateRowColor">#FFFFFF</Color>
    <Color x:Key="DataGridHeaderBackgroundColor">#FFFFFF</Color>
    <Color x:Key="DataGridHeaderTextColor">#B0FFFFFF</Color>
    <Color x:Key="DataGridBorderColor">#FFFFFF</Color>
    <Color x:Key="DataGridSelectedRowColor">#FFFFFF</Color>
    <Color x:Key="FormLabelColor">#B0FFFFFF</Color>
    <Color x:Key="SectionCardBackgroundColor">#FFFFFF</Color>
    
    <!-- Brush Resources -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="FormLabelBrush" Color="{StaticResource FormLabelColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" Opacity="0.2" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}" Opacity="0.15" />
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="{StaticResource BorderColor}" Opacity="0.2" />
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="{StaticResource ToolbarBackgroundColor}" Opacity="0.1" />
    <SolidColorBrush x:Key="ToolbarBorderBrush" Color="{StaticResource BorderColor}" Opacity="0.2" />
    <SolidColorBrush x:Key="SearchBarBackgroundBrush" Color="{StaticResource SearchBarBackgroundColor}" Opacity="0.08" />
    <SolidColorBrush x:Key="DataGridRowBrush" Color="{StaticResource DataGridRowColor}" Opacity="0.15" />
    <SolidColorBrush x:Key="DataGridAlternateRowBrush" Color="{StaticResource DataGridAlternateRowColor}" Opacity="0.1" />
    <SolidColorBrush x:Key="DataGridHeaderBackgroundBrush" Color="{StaticResource DataGridHeaderBackgroundColor}" Opacity="0.2" />
    <SolidColorBrush x:Key="DataGridHeaderTextBrush" Color="{StaticResource DataGridHeaderTextColor}" />
    <SolidColorBrush x:Key="DataGridBorderBrush" Color="{StaticResource DataGridBorderColor}" Opacity="0.3" />
    <SolidColorBrush x:Key="DataGridSelectedRowBrush" Color="{StaticResource DataGridSelectedRowColor}" Opacity="0.3" />
    <SolidColorBrush x:Key="SectionCardBackgroundBrush" Color="{StaticResource SectionCardBackgroundColor}" Opacity="0.1" />
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#FFFFFF" Opacity="0.2" />
    
    <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0,0" EndPoint="0,1" Opacity="0.3">
        <GradientStop Color="#1a1a2e" Offset="0"/>
        <GradientStop Color="#0f3460" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
