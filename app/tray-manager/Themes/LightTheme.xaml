<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Color Definitions -->
    <Color x:Key="PrimaryBackgroundColor">#F5F5F5</Color>
    <Color x:Key="SecondaryBackgroundColor">#FFFFFF</Color>
    <Color x:Key="PrimaryTextColor">#1a1a1a</Color>
    <Color x:Key="SecondaryTextColor">#666666</Color>
    <Color x:Key="BorderColor">#000000</Color>
    <Color x:Key="SidebarBackgroundColor">#FFFFFF</Color>
    <Color x:Key="ToolbarBackgroundColor">#FFFFFF</Color>
    <Color x:Key="SearchBarBackgroundColor">#FFFFFF</Color>
    <Color x:Key="DataGridRowColor">#F8F8F8</Color>
    <Color x:Key="DataGridAlternateRowColor">#FFFFFF</Color>
    <Color x:Key="DataGridHeaderBackgroundColor">#E8E8E8</Color>
    <Color x:Key="DataGridHeaderTextColor">#555555</Color>
    <Color x:Key="DataGridBorderColor">#D0D0D0</Color>
    <Color x:Key="DataGridSelectedRowColor">#D0D0D0</Color>
    <Color x:Key="FormLabelColor">#555555</Color>
    <Color x:Key="SectionCardBackgroundColor">#FFFFFF</Color>
    
    <!-- Brush Resources -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="FormLabelBrush" Color="{StaticResource FormLabelColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" Opacity="0.3" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}" Opacity="0.15" />
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="{StaticResource BorderColor}" Opacity="0.3" />
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="{StaticResource ToolbarBackgroundColor}" Opacity="0.15" />
    <SolidColorBrush x:Key="ToolbarBorderBrush" Color="{StaticResource BorderColor}" Opacity="0.3" />
    <SolidColorBrush x:Key="SearchBarBackgroundBrush" Color="{StaticResource SearchBarBackgroundColor}" Opacity="0.08" />
    <SolidColorBrush x:Key="DataGridRowBrush" Color="{StaticResource DataGridRowColor}" />
    <SolidColorBrush x:Key="DataGridAlternateRowBrush" Color="{StaticResource DataGridAlternateRowColor}" />
    <SolidColorBrush x:Key="DataGridHeaderBackgroundBrush" Color="{StaticResource DataGridHeaderBackgroundColor}" />
    <SolidColorBrush x:Key="DataGridHeaderTextBrush" Color="{StaticResource DataGridHeaderTextColor}" />
    <SolidColorBrush x:Key="DataGridBorderBrush" Color="{StaticResource DataGridBorderColor}" />
    <SolidColorBrush x:Key="DataGridSelectedRowBrush" Color="{StaticResource DataGridSelectedRowColor}" />
    <SolidColorBrush x:Key="SectionCardBackgroundBrush" Color="{StaticResource SectionCardBackgroundColor}" Opacity="0.8" />
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#000000" Opacity="0.3" />
    <SolidColorBrush x:Key="FooterIconBrush" Color="#333333" />
    
    <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0,0" EndPoint="0,1" Opacity="0.6">
        <GradientStop Color="#F5F5F5" Offset="0"/>
        <GradientStop Color="#FFFFFF" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
