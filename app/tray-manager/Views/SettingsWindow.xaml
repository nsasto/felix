<Window x:Class="FelixTrayManager.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Felix Tray Manager - Settings" 
        Height="400" 
        Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">
    
    <Window.Resources>
        <!-- Style for section headers -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
        
        <!-- Style for labels -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        
        <!-- Style for validation messages -->
        <Style x:Key="ValidationStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Settings" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Margin="0,0,0,15"/>

        <!-- Settings Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- Project Configuration Section -->
                <TextBlock Text="Project Configuration" Style="{StaticResource SectionHeaderStyle}"/>
                <Separator Margin="0,0,0,10"/>
                
                <!-- Project Path -->
                <TextBlock Text="Felix Project Path:" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="ProjectPathTextBox" 
                             Grid.Column="0"
                             Height="25"
                             VerticalContentAlignment="Center"
                             Margin="0,0,10,0"
                             TextChanged="OnProjectPathChanged"/>
                    
                    <Button x:Name="BrowseButton" 
                            Grid.Column="1"
                            Content="Browse..."
                            Width="80"
                            Height="25"
                            Click="OnBrowseClick"/>
                </Grid>
                <TextBlock x:Name="ValidationMessage" 
                           Style="{StaticResource ValidationStyle}"
                           Visibility="Collapsed"/>

                <!-- Max Iterations -->
                <TextBlock Text="Maximum Iterations:" 
                           Style="{StaticResource LabelStyle}"
                           Margin="0,15,0,0"/>
                <TextBlock Text="The maximum number of iterations the Felix agent will execute before stopping." 
                           FontSize="11"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           Margin="0,2,0,5"/>
                <TextBox x:Name="MaxIterationsTextBox" 
                         Width="100"
                         Height="25"
                         HorizontalAlignment="Left"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="OnNumericPreviewTextInput"/>

                <!-- Behavior Section -->
                <TextBlock Text="Behavior" 
                           Style="{StaticResource SectionHeaderStyle}"
                           Margin="0,20,0,5"/>
                <Separator Margin="0,0,0,10"/>

                <!-- Auto-start on Login -->
                <CheckBox x:Name="AutoStartCheckBox"
                          Content="Start Felix Tray Manager automatically when I log in to Windows"
                          Margin="0,5,0,0"/>
                
                <TextBlock Text="This will add the application to your Windows startup programs." 
                           FontSize="11"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           Margin="20,2,0,0"/>

                <!-- Run in Background on Close -->
                <CheckBox x:Name="RunInBackgroundCheckBox"
                          Content="Minimize to tray instead of closing when I click the window close button"
                          Margin="0,15,0,0"/>
                
                <TextBlock Text="When enabled, closing the Settings window will minimize the application to the system tray instead of exiting." 
                           FontSize="11"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           Margin="20,2,0,0"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="ResetButton"
                    Grid.Column="0"
                    Content="Reset to Defaults"
                    Width="120"
                    Height="30"
                    HorizontalAlignment="Left"
                    Click="OnResetClick"/>

            <Button x:Name="CancelButton"
                    Grid.Column="1"
                    Content="Cancel"
                    Width="80"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="OnCancelClick"/>

            <Button x:Name="SaveButton"
                    Grid.Column="2"
                    Content="Save"
                    Width="80"
                    Height="30"
                    IsDefault="True"
                    Click="OnSaveClick"/>
        </Grid>
    </Grid>
</Window>
