<Window x:Class="FelixTrayManager.Views.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Felix Agent Output" 
        Height="600" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Felix Agent Console Output" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="StatusText" Text="Status: Running" FontSize="12" Foreground="#A0A0A0" Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ClearButton" Content="Clear" Width="80" Height="30" Margin="0,0,10,0" Click="OnClearClick"/>
                    <Button x:Name="CopyButton" Content="Copy All" Width="80" Height="30" Click="OnCopyClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="0,1">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="LogTextBox" Background="#1E1E1E" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="12" IsReadOnly="True" BorderThickness="0" TextWrapping="NoWrap" Padding="10"/>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="#007ACC" Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="💡 Real-time output from Felix agent" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                <CheckBox x:Name="AutoScrollCheckBox" Grid.Column="1" Content="Auto-scroll" Foreground="White" IsChecked="True" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
