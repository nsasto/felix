<ui:FluentWindow x:Class="FelixTrayApp.Views.MainWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                xmlns:vm="clr-namespace:FelixTrayApp.ViewModels"
                mc:Ignorable="d"
                Title="Felix Tray App"
                Width="1100"
                Height="700"
                WindowBackdropType="Mica"
                WindowCornerPreference="Round"
                ExtendsContentIntoTitleBar="True"
                WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <!-- Gradient overlay for deeper color while showing Mica through -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1" Opacity="0.3">
                <GradientStop Color="#1a1a2e" Offset="0" />
                <GradientStop Color="#0f3460" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Panel -->
        <Border Grid.Column="0" Background="#15000000" BorderBrush="#20FFFFFF" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Title -->
                <TextBlock Grid.Row="0" Text="F" FontSize="20" FontWeight="SemiBold" 
                           Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" />

                <!-- Navigation Items -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0" HorizontalAlignment="Center">
                    <ui:Button Icon="{ui:SymbolIcon Desktop24}" 
                              Appearance="Secondary"
                              ToolTip="Agents"
                              Margin="0,4" />
                    <ui:Button Icon="{ui:SymbolIcon DocumentText24}" 
                              Appearance="Secondary"
                              ToolTip="Logs"
                              Margin="0,4" />
                    <ui:Button Icon="{ui:SymbolIcon Settings24}" 
                              Appearance="Secondary"
                              ToolTip="Settings"
                              Margin="0,4" />
                </StackPanel>

                <!-- Footer with User Info -->
                <Border Grid.Row="2" Margin="8" Padding="8" Background="#20FFFFFF" CornerRadius="8">
                    <ui:SymbolIcon Symbol="Person24" FontSize="20" Foreground="White" 
                                  HorizontalAlignment="Center"
                                  ToolTip="{Binding Path=UserName, FallbackValue='User'}" />
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Toolbar -->
            <Border Grid.Row="0" Background="#10000000" BorderBrush="#20FFFFFF" 
                    BorderThickness="0,0,0,1" Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Column="0" Text="Felix Agent Manager" 
                              FontSize="16" FontWeight="SemiBold" Foreground="White"
                              VerticalAlignment="Center" />

                    <!-- Controls -->
                    <ui:Button Grid.Column="1" 
                              Icon="{ui:SymbolIcon Dismiss24}" 
                              ToolTip="Close Window"
                              Appearance="Secondary"
                              Click="CloseButton_Click" />
                </Grid>
            </Border>

            <!-- Search and Filter Bar -->
            <Border Grid.Row="1" Background="#08000000" Padding="20,12" Visibility="{Binding ShowAgentsList, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <ui:TextBox PlaceholderText="search agents" 
                                   Icon="{ui:SymbolIcon Search24}" Width="300" 
                                   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                   Margin="0,0,12,0" />
                        <ui:Button Content="Add Agent" Icon="{ui:SymbolIcon AddCircle24}" 
                                  Appearance="Primary" Command="{Binding AddAgentCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="#B0FFFFFF">
                        <Run Text="{Binding FilteredAgents.Count, Mode=OneWay}" />
                        <Run Text="agent(s) configured" />
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Agents Table -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding ShowAgentsList, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Section Title -->
                <TextBlock Grid.Row="0" Text="Agents" FontSize="18" FontWeight="SemiBold" 
                           Foreground="White" Margin="0,0,0,12" />

                <!-- DataGrid -->
                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding FilteredAgents}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="#15FFFFFF"
                          AlternatingRowBackground="#10FFFFFF"
                          RowHeight="48">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#20FFFFFF" />
                            <Setter Property="Foreground" Value="#B0FFFFFF" />
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="BorderBrush" Value="#30FFFFFF" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="Padding" Value="12,0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#30FFFFFF" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*" />
                        
                        <!-- Status Column with Icon -->
                        <DataGridTemplateColumn Header="Status" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon FontSize="16" Margin="0,0,8,0">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DisplayStatus}" Value="Disabled">
                                                            <Setter Property="Symbol" Value="Dismiss24" />
                                                            <Setter Property="Foreground" Value="#757575" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DisplayStatus}" Value="Idle">
                                                            <Setter Property="Symbol" Value="Record24" />
                                                            <Setter Property="Foreground" Value="#9E9E9E" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DisplayStatus}" Value="Busy">
                                                            <Setter Property="Symbol" Value="ArrowSync24" />
                                                            <Setter Property="Foreground" Value="#4CAF50" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DisplayStatus}" Value="Error">
                                                            <Setter Property="Symbol" Value="ErrorCircle24" />
                                                            <Setter Property="Foreground" Value="#F44336" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                        <TextBlock Text="{Binding DisplayStatus}" Foreground="White" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Last Run" Binding="{Binding LastRunFormatted}" Width="160" />
                        <DataGridTextColumn Header="Last Feature Name" Binding="{Binding LastFeatureName}" Width="250" />

                        <!-- Operations Column with Buttons -->
                        <DataGridTemplateColumn Header="Operations" Width="250">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:Button Icon="{ui:SymbolIcon Settings24}" 
                                                  Appearance="Secondary"
                                                  ToolTip="Configure Agent"
                                                  Command="{Binding DataContext.ConfigureAgentCommand, 
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  CommandParameter="{Binding}" Margin="0,0,8,0" />
                                        <ui:Button Icon="{ui:SymbolIcon History24}" 
                                                  Appearance="Secondary"
                                                  ToolTip="View Run History"
                                                  Command="{Binding DataContext.ShowRunHistoryCommand, 
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  CommandParameter="{Binding}" Margin="0,0,8,0" />
                                        <ui:Button ToolTip="Toggle Active Status" 
                                                  Appearance="Secondary"
                                                  Command="{Binding DataContext.ToggleAgentActiveCommand, 
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  CommandParameter="{Binding}" Margin="0,0,8,0">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Icon" Value="{ui:SymbolIcon Checkmark24}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Icon" Value="{ui:SymbolIcon Dismiss24}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" 
                                                  Appearance="Secondary"
                                                  ToolTip="Remove Agent"
                                                  Command="{Binding DataContext.RemoveAgentCommand, 
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Agent Settings Form -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding ShowAgentSettings, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Section Title -->
                <TextBlock Grid.Row="0" Text="Agent Settings" FontSize="18" FontWeight="SemiBold" 
                           Foreground="White" Margin="0,0,0,20" />

                <!-- Settings Form -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        
                        <!-- Name (Auto) -->
                        <TextBlock Text="Name (auto-generated)" Foreground="#B0FFFFFF" Margin="0,0,0,8" />
                        <ui:TextBox Text="{Binding SelectedAgent.Name}" 
                                   IsReadOnly="True"
                                   Margin="0,0,0,20" />

                        <!-- Friendly Name -->
                        <TextBlock Text="Friendly Name" Foreground="#B0FFFFFF" Margin="0,0,0,8" />
                        <ui:TextBox Text="{Binding SelectedAgent.FriendlyName, UpdateSourceTrigger=PropertyChanged}" 
                                   PlaceholderText="Enter a custom display name"
                                   Margin="0,0,0,20" />

                        <!-- Path to Agent -->
                        <TextBlock Text="Path to Agent Script" Foreground="#B0FFFFFF" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" 
                                       Text="{Binding SelectedAgent.AgentPath, UpdateSourceTrigger=PropertyChanged}" 
                                       PlaceholderText="C:\path\to\felix-agent.ps1"
                                       Margin="0,0,8,0" />
                            <ui:Button Grid.Column="1" 
                                      Content="Browse..." 
                                      Command="{Binding BrowseAgentPathCommand}" />
                        </Grid>

                        <!-- Project Folder -->
                        <TextBlock Text="Project Folder" Foreground="#B0FFFFFF" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" 
                                       Text="{Binding SelectedAgent.ProjectFolder, UpdateSourceTrigger=PropertyChanged}" 
                                       PlaceholderText="C:\projects\roboza\felix"
                                       Margin="0,0,8,0" />
                            <ui:Button Grid.Column="1" 
                                      Content="Browse..." 
                                      Command="{Binding BrowseProjectFolderCommand}" />
                        </Grid>

                        <!-- Enabled Toggle -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Enabled" Foreground="White" VerticalAlignment="Center" />
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding SelectedAgent.IsActive}" />
                        </Grid>

                        <!-- Enable Logging Toggle -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Enable Logging" Foreground="White" VerticalAlignment="Center" />
                            <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding SelectedAgent.EnableLogging}" />
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

                <!-- Action Buttons -->
                <Border Grid.Row="2" BorderBrush="#30FFFFFF" BorderThickness="0,1,0,0" Padding="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0" 
                                  Content="Delete" 
                                  Icon="{ui:SymbolIcon Delete24}"
                                  Appearance="Danger"
                                  Command="{Binding DeleteAgentCommand}" />

                        <ui:Button Grid.Column="2" 
                                  Content="Cancel" 
                                  Appearance="Secondary"
                                  Command="{Binding CancelSettingsCommand}"
                                  Margin="0,0,12,0" />

                        <ui:Button Grid.Column="3" 
                                  Content="Save" 
                                  Icon="{ui:SymbolIcon Save24}"
                                  Appearance="Primary"
                                  Command="{Binding SaveAgentCommand}" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Run History View -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding ShowRunHistoryView, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header with Back Button -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <ui:Button Grid.Column="0" 
                              Content="Back to Agents" 
                              Icon="{ui:SymbolIcon ArrowLeft24}"
                              Command="{Binding BackToAgentsListCommand}"
                              Margin="0,0,20,0" />
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Run History" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                        <TextBlock Text="{Binding SelectedAgent.DisplayName}" FontSize="14" Foreground="#B0FFFFFF" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Split View: Runs List and Details -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Runs List -->
                    <Border Grid.Column="0" Background="#10FFFFFF" CornerRadius="8" Margin="0,0,10,0" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Recent Runs" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12" />
                            
                            <ListBox Grid.Row="1" 
                                    ItemsSource="{Binding RunHistoryItems}"
                                    SelectedItem="{Binding SelectedRun}"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="White" Padding="8,4" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Run Details with Tabs -->
                    <Border Grid.Column="1" Background="#10FFFFFF" CornerRadius="8" Padding="12">
                        <TabControl>
                            <TabItem Header="Report">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding ReportContent, Mode=OneWay}" 
                                            TextWrapping="Wrap" 
                                            IsReadOnly="True"
                                            Background="Transparent"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Padding="12" />
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Output Log">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding OutputLogContent, Mode=OneWay}" 
                                            TextWrapping="Wrap" 
                                            IsReadOnly="True"
                                            Background="Transparent"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontFamily="Consolas"
                                            Padding="12" />
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Plan Snapshot">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding PlanSnapshotContent, Mode=OneWay}" 
                                            TextWrapping="Wrap" 
                                            IsReadOnly="True"
                                            Background="Transparent"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Padding="12" />
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
