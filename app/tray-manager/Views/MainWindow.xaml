<ui:FluentWindow x:Class="FelixTrayApp.Views.MainWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                xmlns:vm="clr-namespace:FelixTrayApp.ViewModels"
                mc:Ignorable="d"
                Title="Felix Tray App"
                Width="1100"
                Height="700"
                WindowBackdropType="Mica"
                WindowCornerPreference="Round"
                ExtendsContentIntoTitleBar="True"
                WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <!-- Gradient overlay for deeper color while showing Mica through -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1" Opacity="0.3">
                <GradientStop Color="#1a1a2e" Offset="0" />
                <GradientStop Color="#0f3460" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Panel -->
        <Border Grid.Column="0" Background="#15000000" BorderBrush="#20FFFFFF" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Title -->
                <TextBlock Grid.Row="0" Text="Felix" FontSize="20" FontWeight="SemiBold" 
                           Foreground="White" VerticalAlignment="Center" Margin="20,0" />

                <!-- Navigation Items -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <ui:NavigationViewItem Content="Agents" Icon="{ui:SymbolIcon Computer24}" 
                                          Margin="8,2" IsActive="True" />
                    <ui:NavigationViewItem Content="Logs" Icon="{ui:SymbolIcon Document24}" 
                                          Margin="8,2" />
                    <ui:NavigationViewItem Content="Settings" Icon="{ui:SymbolIcon Settings24}" 
                                          Margin="8,2" />
                </StackPanel>

                <!-- Footer with User Info -->
                <Border Grid.Row="2" Margin="12" Padding="12" Background="#20FFFFFF" CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Person24" FontSize="20" Foreground="White" />
                        <TextBlock Text="{Binding Path=(local:App.Current).User, FallbackValue='User'}" 
                                   Margin="12,0,0,0" VerticalAlignment="Center" 
                                   Foreground="White" FontSize="14" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Toolbar -->
            <Border Grid.Row="0" Background="#10000000" BorderBrush="#20FFFFFF" 
                    BorderThickness="0,0,0,1" Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Column="0" Text="Felix Agent Manager" 
                              FontSize="16" FontWeight="SemiBold" Foreground="White"
                              VerticalAlignment="Center" />

                    <!-- Controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ui:Button Icon="{ui:SymbolIcon Document24}" 
                                  ToolTip="View Logs"
                                  Appearance="Secondary" Margin="0,0,8,0" />
                        <ui:Button Icon="{ui:SymbolIcon Settings24}" 
                                  ToolTip="Settings"
                                  Appearance="Secondary" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Search and Filter Bar -->
            <Border Grid.Row="1" Background="#08000000" Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <ui:TextBox PlaceholderText="search agents" 
                                   Icon="{ui:SymbolIcon Search24}" Width="300" 
                                   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                   Margin="0,0,12,0" />
                        <ui:Button Content="Add Agent" Icon="{ui:SymbolIcon Add24}" 
                                  Appearance="Primary" Command="{Binding AddAgentCommand}" />
                    </StackPanel>

                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="#B0FFFFFF">
                        <Run Text="{Binding FilteredAgents.Count, Mode=OneWay}" />
                        <Run Text="agent(s) configured" />
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Agents Table -->
            <Grid Grid.Row="2" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Section Title -->
                <TextBlock Grid.Row="0" Text="Agents" FontSize="18" FontWeight="SemiBold" 
                           Foreground="White" Margin="0,0,0,12" />

                <!-- DataGrid -->
                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding FilteredAgents}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="#15FFFFFF"
                          AlternatingRowBackground="#10FFFFFF"
                          RowHeight="48">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#20FFFFFF" />
                            <Setter Property="Foreground" Value="#B0FFFFFF" />
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="BorderBrush" Value="#30FFFFFF" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="Padding" Value="12,0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#30FFFFFF" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        
                        <!-- Status Column with Icon -->
                        <DataGridTemplateColumn Header="Status" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon FontSize="16" Margin="0,0,8,0">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Idle">
                                                            <Setter Property="Symbol" Value="Circle24" />
                                                            <Setter Property="Foreground" Value="#9E9E9E" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Busy">
                                                            <Setter Property="Symbol" Value="ArrowSync24" />
                                                            <Setter Property="Foreground" Value="#4CAF50" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Error">
                                                            <Setter Property="Symbol" Value="ErrorCircle24" />
                                                            <Setter Property="Foreground" Value="#F44336" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                        <TextBlock Text="{Binding Status}" Foreground="White" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Last Run" Binding="{Binding LastRunFormatted}" Width="160" />
                        <DataGridTextColumn Header="Last Feature Name" Binding="{Binding LastFeatureName}" Width="250" />

                        <!-- Operations Column with Buttons -->
                        <DataGridTemplateColumn Header="Operations" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:Button Icon="{ui:SymbolIcon Settings24}" 
                                                  Appearance="Secondary"
                                                  ToolTip="Configure Agent"
                                                  Command="{Binding DataContext.ConfigureAgentCommand, 
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  CommandParameter="{Binding}" Margin="0,0,8,0" />
                                        <ui:Button ToolTip="Toggle Active Status" 
                                                  Appearance="Secondary"
                                                  Command="{Binding DataContext.ToggleAgentActiveCommand, 
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  CommandParameter="{Binding}" Margin="0,0,8,0">
                                            <ui:Button.Content>
                                                <ui:SymbolIcon Symbol="{Binding IsActive, Converter={StaticResource BoolToToggleIconConverter}}" />
                                            </ui:Button.Content>
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Icon" Value="{ui:SymbolIcon Checkmark24}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Icon" Value="{ui:SymbolIcon Dismiss24}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" 
                                                  Appearance="Secondary"
                                                  ToolTip="Remove Agent"
                                                  Command="{Binding DataContext.RemoveAgentCommand, 
                                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
