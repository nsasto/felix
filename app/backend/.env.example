# Felix Backend Environment Configuration

# Database connection string (required)
DATABASE_URL=postgresql://postgres@localhost:5432/felix

# Authentication mode: "disabled" for dev, "enabled" for production (future)
AUTH_MODE=disabled

# Development defaults (used when AUTH_MODE=disabled)
DEV_ORG_ID=00000000-0000-0000-0000-000000000001
DEV_PROJECT_ID=00000000-0000-0000-0000-000000000001
DEV_USER_ID=dev-user
