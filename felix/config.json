{
  "version": "0.1.0",
  "executor": {
    "mode": "local",
    "max_iterations": 100,
    "default_mode": "planning",
    "auto_transition": true
  },
  "agent": {
    "name": "felix-primary",
    "executable": "droid",
    "args": [
      "exec",
      "--skip-permissions-unsafe"
    ],
    "working_directory": ".",
    "environment": {}
  },
  "paths": {
    "specs": "specs",
    "agents": "AGENTS.md",
    "runs": "runs"
  },
  "backpressure": {
    "enabled": true,
    "commands": []
  },
  "ui": {
    "theme": "dark"
  }
}