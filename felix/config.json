{
  "version": "0.1.0",
  "executor": {
    "mode": "local",
    "max_iterations": 100,
    "default_mode": "building",
    "auto_transition": true
  },
  "agent": {
    "executable": "droid",
    "args": ["exec", "--skip-permissions-unsafe"],
    "working_directory": ".",
    "environment": {}
  },
  "python": {
    "executable": "py",
    "args": ["-3"]
  },
  "paths": {
    "felix_root": ".",
    "specs": "specs",
    "agents": "AGENTS.md",
    "runs": "runs"
  },
  "backpressure": {
    "enabled": true,
    "commands": [],
    "max_retries": 3
  },
  "plugins": {
    "enabled": true,
    "discovery_path": "felix/plugins",
    "api_version": "v1",
    "disabled": [],
    "state_retention_days": 7,
    "circuit_breaker_max_failures": 3
  }
}
